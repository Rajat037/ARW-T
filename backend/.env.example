# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=your_database_name
DB_INIT_DATABASE=postgres
DB_SSL=false
# Optional: use DATABASE_URL instead of DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com

# Auth & application settings
JWT_SECRET=your_strong_random_jwt_secret
PORT=3005
FRONTEND_ORIGIN=http://localhost:5173

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Firebase Admin SDK
# Add the full JSON payload in one line, with literal \n characters inside private_key.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"your_private_key_id","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"your-service-account@your-project-id.iam.gserviceaccount.com","client_id":"your_client_id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/your-service-account@your-project-id.iam.gserviceaccount.com","universe_domain":"googleapis.com"}

# Optional AI / third-party keys
OPENAI_API_KEY=your_openai_api_key
